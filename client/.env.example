# Local dev. In production, set this to your Render web service URL + /api (copy the hostname exactly from the Render dashboard — a wrong hyphen, e.g. eventwith-ease vs eventwithease, gives 404 / “no-server”).
VITE_API_URL=http://localhost:5000/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
